---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import CertificateCard from '../components/CertificateCard.astro';
import { profile, experienceItems } from '../data/profile';
import { skillCategories } from '../data/skills';
import { flagshipProjects } from '../data/projects';
import { certifications } from '../data/certifications';
---
<BaseLayout
  title="Resume — Sibghatullah Laghari | Backend Engineer"
  description="Resume of Sibghatullah Laghari — Backend Engineer specializing in Java, Spring Boot, REST APIs, and secure database-driven systems."
>

<section class="sec">
  <div class="wrap">
    <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:1.5rem;margin-bottom:3rem;">
      <SectionHeader
        eyebrow="Resume"
        title={profile.name}
        description={`${profile.title} · ${profile.location} · Last updated ${profile.resumeLastUpdated}`}
      />
      <div style="display:flex;flex-wrap:wrap;gap:.75rem;">
        <a href={profile.resumePath} download class="btn btn-primary">
          Download Resume
        </a>
        <a href={profile.resumePath} target="_blank" rel="noopener" class="btn btn-outline">
          Open PDF
        </a>
      </div>
    </div>

    <!-- Web Resume -->
    <div class="card resume-doc" style="margin-bottom:2rem;">
      <header style="border-bottom:1px solid var(--border);padding-bottom:1.5rem;margin-bottom:1.5rem;">
        <h2 style="font-size:1.5rem;font-weight:800;margin-bottom:.35rem;">{profile.name}</h2>
        <p style="color:var(--accent2);font-weight:600;margin-bottom:.75rem;">{profile.title} · Java · Spring Boot · REST APIs</p>
        <p style="font-size:.875rem;color:var(--txt2);">
          {profile.email} · {profile.location} ·
          <a href={profile.github} target="_blank" rel="noopener" style="color:var(--accent2);">GitHub</a> ·
          <a href={profile.linkedin} target="_blank" rel="noopener" style="color:var(--accent2);">LinkedIn</a>
        </p>
      </header>

      <section style="margin-bottom:2rem;">
        <h3 class="resume-heading">Summary</h3>
        <p style="font-size:.9rem;color:var(--txt2);line-height:1.8;">
          Backend engineer who builds secure REST APIs, authentication systems, and database-driven services with Java and Spring Boot.
          Focused on layered architecture, RBAC, and shipping software that solves real problems. Open to internships, full-time, and freelance work.
        </p>
      </section>

      <section style="margin-bottom:2rem;">
        <h3 class="resume-heading">Experience</h3>
        {experienceItems.map(item => (
          <div style="margin-bottom:1.5rem;">
            <div style="display:flex;flex-wrap:wrap;justify-content:space-between;gap:.5rem;margin-bottom:.5rem;">
              <strong style="font-size:.95rem;">{item.role}</strong>
              <span style="font-size:.8rem;color:var(--txt3);">{item.period}</span>
            </div>
            <p style="font-size:.85rem;color:var(--accent2);margin-bottom:.5rem;">{item.org}</p>
            <ul style="list-style:disc;padding-left:1.25rem;display:flex;flex-direction:column;gap:.35rem;">
              {item.bullets.slice(0, 4).map(b => (
                <li style="font-size:.84rem;color:var(--txt2);line-height:1.6;">{b}</li>
              ))}
            </ul>
          </div>
        ))}
      </section>

      <section style="margin-bottom:2rem;">
        <h3 class="resume-heading">Education</h3>
        <div style="display:flex;flex-wrap:wrap;justify-content:space-between;gap:.5rem;margin-bottom:.35rem;">
          <strong style="font-size:.95rem;">{profile.education.degree}</strong>
          <span style="font-size:.8rem;color:var(--txt3);">{profile.education.period}</span>
        </div>
        <p style="font-size:.85rem;color:var(--accent2);">{profile.education.university}</p>
        <p style="font-size:.84rem;color:var(--txt2);margin-top:.35rem;">
          {profile.education.semester} · CGPA {profile.education.cgpa}
        </p>
      </section>

      <section style="margin-bottom:2rem;">
        <h3 class="resume-heading">Key Projects</h3>
        {flagshipProjects.map(p => (
          <div style="margin-bottom:1rem;">
            <strong style="font-size:.9rem;">{p.title} — {p.subtitle}</strong>
            <p style="font-size:.84rem;color:var(--txt2);margin-top:.25rem;line-height:1.6;">{p.impact}</p>
          </div>
        ))}
      </section>

      <section>
        <h3 class="resume-heading">Technical Skills</h3>
        <div style="display:flex;flex-direction:column;gap:.75rem;">
          {skillCategories.map(cat => (
            <div>
              <strong style="font-size:.82rem;color:var(--txt);">{cat.title}:</strong>
              <span style="font-size:.84rem;color:var(--txt2);"> {cat.skills.join(', ')}</span>
            </div>
          ))}
        </div>
      </section>
    </div>

    {certifications.length > 0 && (
      <div style="margin-bottom:2rem;">
        <h3 class="resume-heading" style="margin-bottom:1rem;">Certifications</h3>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem;">
          {certifications.map(cert => <CertificateCard cert={cert} />)}
        </div>
      </div>
    )}

    <div style="text-align:center;padding:1.5rem;border:1px dashed var(--border);border-radius:.75rem;">
      <p style="font-size:.875rem;color:var(--txt2);margin-bottom:1rem;">
        PDF resume available for download · Last updated {profile.resumeLastUpdated}
      </p>
      <a href={profile.resumePath} download class="btn btn-primary">Download PDF Resume</a>
    </div>
  </div>
</section>

<style>
  .resume-heading {
    font-size: .75rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: .75rem;
  }
  .resume-doc:hover {
    transform: none;
  }
</style>

</BaseLayout>
