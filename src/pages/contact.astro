---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeader from '../components/SectionHeader.astro';
import ContactCard from '../components/ContactCard.astro';
import { profile } from '../data/profile';
---
<BaseLayout
  title="Contact — Sibghatullah Laghari | Backend Engineer"
  description="Contact Sibghatullah Laghari for backend engineering opportunities, internships, freelance projects, and collaborations. Remote, hybrid, and relocation available."
>

<section class="sec" style="min-height:85vh;background:radial-gradient(ellipse 70% 50% at 50% 0,rgba(99,102,241,.1) 0%,transparent 60%),var(--bg);">
  <div class="wrap">
    <SectionHeader
      eyebrow="Get In Touch"
      title="Let's Build Something"
      description="Open to backend engineering roles, internships, freelance work, and technical collaboration. I respond within 24 hours."
      centered={true}
    />

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:2.5rem;align-items:start;" class="contact-grid">

      <div style="display:flex;flex-direction:column;gap:1rem;">
        <ContactCard label="Email" value={profile.email} href={`mailto:${profile.email}`} hint="Preferred contact method">
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </ContactCard>

        <ContactCard label="LinkedIn" value="linkedin.com/in/sibghatullah-laghari" href={profile.linkedin} hint="Connect professionally" external={true}>
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </ContactCard>

        <ContactCard label="GitHub" value="github.com/sibghatullah-laghari" href={profile.github} hint="Projects & open source" external={true}>
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        </ContactCard>

        <ContactCard label="Fiverr" value="fiverr.com/sibghatullah-laghari" href={profile.fiverr} hint="Freelance backend projects" external={true}>
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
        </ContactCard>

        <ContactCard label="Resume" value="Download PDF" href={profile.resumePath} hint={`Last updated ${profile.resumeLastUpdated}`}>
          <svg slot="icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </ContactCard>
      </div>

      <div style="display:flex;flex-direction:column;gap:1.25rem;">
        <div style="padding:2rem;background:linear-gradient(135deg,rgba(34,197,94,.08),rgba(99,102,241,.08));border:1px solid rgba(34,197,94,.2);border-radius:1rem;">
          <div style="display:flex;align-items:center;gap:.5rem;margin-bottom:1rem;">
            <span class="pulse-dot" style="width:8px;height:8px;border-radius:50%;background:#22c55e;display:inline-block;"></span>
            <span style="font-size:.7rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#4ade80;">Open to Opportunities</span>
          </div>
          <h3 style="font-size:1.2rem;font-weight:800;margin-bottom:.5rem;">Available for Work</h3>
          <p style="font-size:.875rem;color:var(--txt2);line-height:1.7;margin-bottom:1.25rem;">
            Internships, full-time backend roles, freelance API development, and remote collaboration.
          </p>
          <div style="display:flex;flex-wrap:wrap;gap:.35rem;margin-bottom:1.5rem;">
            {profile.availability.map(a => <span class="badge badge-green" style="font-size:.65rem;">{a}</span>)}
          </div>
          <a href={`mailto:${profile.email}`} class="btn btn-primary" style="width:100%;justify-content:center;">
            Send Email
          </a>
        </div>

        <div class="card">
          <h4 style="font-size:.85rem;font-weight:700;color:var(--txt2);text-transform:uppercase;letter-spacing:.08em;margin-bottom:1rem;">What I Build</h4>
          <div style="display:flex;flex-direction:column;gap:.75rem;">
            {profile.focus.map(item => (
              <div style="display:flex;align-items:center;gap:.5rem;font-size:.855rem;color:var(--txt2);">
                <span style="width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0;"></span>
                {item}
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media(max-width:768px) { .contact-grid { grid-template-columns:1fr !important; } }
</style>

</BaseLayout>
