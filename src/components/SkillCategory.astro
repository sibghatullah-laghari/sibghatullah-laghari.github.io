---
import type { SkillCategory } from '../data/skills';

export interface Props {
  category: SkillCategory;
}

const { category } = Astro.props;

const borderColors: Record<SkillCategory['variant'], string> = {
  core: 'rgba(99,102,241,.25)',
  security: 'rgba(34,197,94,.25)',
  tools: 'rgba(255,255,255,.1)',
  exploring: 'rgba(251,191,36,.2)',
};
---
<div class="card skill-cat" style={`border-color:${borderColors[category.variant]};padding:1.5rem;`}>
  <h3 style="font-size:.95rem;font-weight:700;margin-bottom:.35rem;">{category.title}</h3>
  <p style="font-size:.8rem;color:var(--txt3);margin-bottom:1rem;line-height:1.6;">{category.description}</p>
  <ul style="list-style:none;display:flex;flex-direction:column;gap:.45rem;">
    {category.skills.map(skill => (
      <li style="display:flex;align-items:center;gap:.5rem;font-size:.875rem;color:var(--txt2);">
        <span style="width:5px;height:5px;border-radius:50%;background:var(--accent);flex-shrink:0;"></span>
        {skill}
      </li>
    ))}
  </ul>
</div>

<style>
  .skill-cat:hover { transform: translateY(-2px); }
</style>
