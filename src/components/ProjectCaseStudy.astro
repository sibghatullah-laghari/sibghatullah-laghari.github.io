---
import type { ProjectCaseStudy } from '../data/projects';

export interface Props {
  project: ProjectCaseStudy;
  compact?: boolean;
}

const { project, compact = false } = Astro.props;
---
<article class={`card project-card ${project.featured ? 'project-featured' : ''}`}>
  <div style="display:flex;flex-wrap:wrap;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:1rem;">
    <div style="flex:1;min-width:0;">
      <div style="display:flex;flex-wrap:wrap;align-items:center;gap:.5rem;margin-bottom:.5rem;">
        {project.featured && <span class="badge badge-green" style="font-size:.65rem;">Featured</span>}
        {project.backendOnly && <span class="badge badge-indigo" style="font-size:.65rem;">Backend API</span>}
        <span class={`badge ${project.status === 'Live' ? 'badge-green' : project.status === 'In Progress' ? 'badge-yellow' : 'badge-indigo'}`} style="font-size:.65rem;">
          {project.status}
        </span>
      </div>
      <h3 style={`font-weight:800;line-height:1.3;margin-bottom:.25rem;${compact ? 'font-size:1rem;' : 'font-size:1.2rem;'}`}>
        {project.title}
        <span style="display:block;font-size:.85rem;font-weight:500;color:var(--txt2);margin-top:.2rem;">{project.subtitle}</span>
      </h3>
    </div>
    <a href={project.github} target="_blank" rel="noopener" class="btn btn-outline btn-sm" aria-label={`View ${project.title} on GitHub`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
      GitHub
    </a>
  </div>

  {!compact && (
    <p style="font-size:.9rem;color:var(--txt2);line-height:1.75;margin-bottom:1.25rem;">{project.problem}</p>
  )}

  <div class="case-grid">
    <div class="case-block">
      <span class="case-label">Solution</span>
      <p>{project.solution}</p>
    </div>
    <div class="case-block">
      <span class="case-label">Architecture</span>
      <p>{project.architecture}</p>
    </div>
    {!compact && (
      <>
        <div class="case-block">
          <span class="case-label">Key Features</span>
          <ul>
            {project.keyFeatures.map(f => <li>{f}</li>)}
          </ul>
        </div>
        <div class="case-block">
          <span class="case-label">Technical Challenge</span>
          <p>{project.challenges}</p>
        </div>
        <div class="case-block">
          <span class="case-label">Biggest Learning</span>
          <p>{project.learning}</p>
        </div>
        <div class="case-block">
          <span class="case-label">Impact</span>
          <p>{project.impact}</p>
        </div>
      </>
    )}
  </div>

  {project.backendOnly && !compact && (
    <div class="arch-diagram" aria-label="MediConnect backend architecture diagram">
      <div class="arch-row">
        <span class="arch-node">Client</span>
        <span class="arch-arrow">→</span>
        <span class="arch-node accent">REST API</span>
        <span class="arch-arrow">→</span>
        <span class="arch-node">Spring Security</span>
      </div>
      <div class="arch-row sub">
        <span class="arch-arrow">↓</span>
      </div>
      <div class="arch-row">
        <span class="arch-node">Service Layer</span>
        <span class="arch-arrow">→</span>
        <span class="arch-node">JPA / Hibernate</span>
        <span class="arch-arrow">→</span>
        <span class="arch-node accent">MySQL</span>
      </div>
    </div>
  )}

  <div style="display:flex;flex-wrap:wrap;gap:.35rem;margin-top:1.25rem;padding-top:1rem;border-top:1px solid var(--border);">
    {project.tech.map(t => <span class="badge badge-indigo" style="font-size:.65rem;">{t}</span>)}
  </div>
</article>

<style>
  .project-featured {
    border-color: rgba(99,102,241,.3);
    background: linear-gradient(135deg, var(--card), var(--card2));
    margin-bottom: 1.5rem;
  }
  .case-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .case-block {
    background: var(--card2);
    border: 1px solid var(--border);
    border-radius: .625rem;
    padding: 1rem;
  }
  .case-label {
    display: block;
    font-size: .68rem;
    font-weight: 700;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: .45rem;
  }
  .case-block p, .case-block li {
    font-size: .84rem;
    color: var(--txt2);
    line-height: 1.65;
  }
  .case-block ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: .35rem;
  }
  .case-block li::before {
    content: '·';
    color: var(--accent);
    margin-right: .4rem;
  }
  .arch-diagram {
    margin-top: 1.25rem;
    padding: 1.25rem;
    background: rgba(99,102,241,.06);
    border: 1px dashed rgba(99,102,241,.25);
    border-radius: .75rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: .75rem;
  }
  .arch-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: .5rem;
  }
  .arch-row.sub { margin: .35rem 0; }
  .arch-node {
    padding: .35rem .65rem;
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: .35rem;
    color: var(--txt2);
  }
  .arch-node.accent {
    border-color: rgba(99,102,241,.4);
    color: var(--accent2);
  }
  .arch-arrow { color: var(--txt3); }
</style>
